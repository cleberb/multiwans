  fi
}

# Testa se a interface de rede estĂ¡ conectada
function testIfaceConnection(){
  local wanId=$1
  local iface=$(getConfig "WANS[$wanId].iface")

  if [ "$(cat /sys/class/net/$iface/carrier 2>&1)" != "1" ]; then
    _error "A interface de rede \"$iface\" estĂ¡ com o cabo de rede desconectado ou sem sinal."
    return 1
  fi
}

# Testa se as configuraĂ§Ăµes da interface de rede estĂ£o corretas
function testIfaceConfiguration(){
  local wanId=$1
  local iface=$(getConfig "WANS[$wanId].iface")
  local ip=$(getConfig "WANS[$wanId].ip")
  local mask=$(getConfig "WANS[$wanId].mask")

  local json_output=$(ip -json addr show dev $iface)
  # Verificar apenas endereĂ§o primĂ¡rio da interface (addr_info[0])
  local current_ip=$($YQ '.[] | .addr_info[0] | select(.family == "inet") | .local' <<< "$json_output")
  local current_mask=$($YQ '.[] | .addr_info[0] | select(.family == "inet") | .prefixlen' <<< "$json_output")

  if [ "$current_ip" == "" ]; then
    _error "A interface de rede \"$iface\" estĂ¡ desconfigurada."
    return 1
  elif [ "${current_ip}/${current_mask}" != "${ip}/${mask}" ]; then
    _error "A interface de rede \"$iface\" estĂ¡ com as configuraĂ§Ăµes fora das definiĂ§Ăµes.\nConfiguraĂ§Ăµes atual: ${current_ip}/${current_mask}."
    return 1
  fi
}

# Resolver endereĂ§os, pesquisando em todos os servidores de DNS disponĂ­veis
function dns(){
  local address=$1

  # Verificar se o endereĂ§o passado por parĂ¢metro Ă© um IP ou URL.
  # Se for IP ele retorna o mesmo como resultado final, se nĂ£o continua no processamento da URL
  local ip_regex="^(([0-9]{1,2}|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\.){3}([0-9]{1,2}|1[0-9][0-9]|2[0-4][0-9]|25[0-5])$"
  if [[ $address =~ $ip_regex ]]; then
    echo "$address"
    return 0
  fi

  local wanId
  for wanId in $(getListIds WANS); do

    local enabled=$(getConfig "WANS[$wanId].enabled")

    # Se estiver desativado, continuar para o prĂ³ximo link WAN
    $enabled || continue

    local status=$(getConfig "WANS[$wanId].status")

    [ "$status" == "OFF" ] && continue

    local orderFailover=$(getConfig "WANS[$wanId].orderFailover")

    # Links WAN com ordem de falha desabilitado, sĂ£o isolados com trĂ¡fegos especĂ­ficos e nĂ£o sĂ£o utilizados como failover.
    # Portanto nĂ£o devem ser utilizados para realizar consultas de DNS
    [ "$orderFailover" == "disabled" ] && continue

    local dns=$(getConfig "WANS[$wanId].dns")
    local ip=$(getConfig "WANS[$wanId].ip")

    # Tentativa de resoluĂ§Ă£o de nome nos servidores DNS
    for server_dns in ${dns//,/\ }; do

      # O comando abaixo captura a saĂ­da do comando dig, retira as linhas que contĂ©m o ip do servidor DNS responsĂ¡vel pela pesquisa;
      # acrescenta ao final de cada linha o carĂ¡cter ":" e o endereĂ§o do servidor DNS. Acrescentar o DNS no final
      # serve para identificar mais tarde que servidor resolveu o endereĂ§o.
      # A opĂ§Ă£o "-b" do comando dig Ă© primordial para identificar por qual link a pesquisa serĂ¡ feita.
      # Caso o endereĂ§o do servidor DNS seja o localhost(127.0.0.1), a opĂ§Ă£o "-b" serĂ¡ ignorada.
      if [ "$server_dns" == "127.0.0.1" ]; then
        local result=$(dig @${server_dns} $address A +tries=$DNS_RETRY +time=$DNS_TIMEOUT +short | grep -v ';\|^$' | sed "s/$/:${server_dns}/g")
      else
        local result=$(dig @${server_dns} -b $ip $address A +tries=$DNS_RETRY +time=$DNS_TIMEOUT +short | grep -v ';\|^$' | sed "s/$/:${server_dns}/g")
      fi

      # Se o endereĂ§o foi resolvido, o sistema retorna os IP(s) e DNS.
      if [ "$result" != "" ]; then
        echo "$result"
        return 0
      else
        _warning "NĂ£o foi possĂ­vel resolver o endereĂ§o \"$address\" via DNS \"$server_dns\"."
      fi
    done
  done

  # Em caso de falha
  _error "NĂ£o foi possĂ­vel resolver o endereĂ§o \"$address\" em nenhum servidor DNS."
  return 1
}

# Teste de conectividade com a internet via ping
function testPing() {
  local wanId="$1"
  local wanIp=$(getConfig "WANS[$wanId].ip")
  local wanPing=$(getConfig "WANS[$wanId].ping")

  for address in ${wanPing}; do
    local dnsResult
    dnsResult=$(dns "$address") || continue

    while IFS=: read -r ip dns; do
      if pingResult=$(ping -I "$wanIp" -q -c "$PING_COUNT" -W "$PING_TIMEOUT" "$ip" 2>&1); then
        if [ "$dns" ]; then
          _success "Ping em ${address} (${ip}). DNS via ${dns}."
        else
          _success "Ping em ${ip}."
        fi
        return 0
      else
        pingResult=$(grep -Eiv 'ping|^[[:space:]]*$' <<< "$pingResult")
        if [ "$dns" ]; then
          _warning "Falha de ping em ${address} (${ip}). DNS via ${dns}:\n${pingResult}"
        else
          _warning "Falha de ping em ${ip}:\n${pingResult}"
        fi
      fi
    done <<< "$dnsResult"
  done
  return 1
}

# Definir status de WAN
function setStatusWan(){
  local wanId="$1"
  local status="$2"

  local current_status=$(getConfig "WANS[$wanId].status")
  local iface=$(getConfig "WANS[$wanId].iface")

  # Registra mudanĂ§a de status em variĂ¡vel global
  [ "$current_status" != "UNKNOW" ] && [ "$current_status" != "$status" ] && WANS_STATE_CHANGE[wanId]=true

  setConfig "WANS[$wanId].status" "$status"

  # Atualizar ou adicionar status da interface no arquivo de status
  if grep -qE "^${iface}:" "$DAEMON_STATUS_FILE" 2>/dev/null; then
    sed -i "s/^${iface}:.*/${iface}:${status}/" "$DAEMON_STATUS_FILE"
  else
    echo "${iface}:${status}" >> "$DAEMON_STATUS_FILE"
  fi
}

# Definir WAN com status "ON"
function setOnWan(){
  local wanId=$1
  local current_status=$(getConfig "WANS[$wanId].status")

  setStatusWan $wanId ON

  # Se status for "UNKNOW", estĂ¡ iniciando o script, nĂ£o foi realizado nenhum teste
  if [ "$current_status" != "UNKNOW" ]; then
    if ${WANS_STATE_CHANGE[$wanId]}; then
      _success "O link estĂ¡ ONLINE! Seu serviĂ§o foi reestabelecido com sucesso!"
    else
      _success "O link estĂ¡ ONLINE!"
    fi
  fi

  scriptHelper up $wanId
}

# Definir WAN com status "OFF"
function setOffWan(){
  local wanId=$1
  local description=$(getConfig "WANS[$wanId].description")
  local orderFailover=$(getConfig "WANS[$wanId].orderFailover")
  local message="${2:-O link estĂ¡ OFFLINE!\nContatar equipe de infraestrutura!}"

  setStatusWan $wanId OFF

  # Link principal(orderFailover=1) nĂ£o possui marcaĂ§Ă£o de pacotes iptables
  if [ "$orderFailover" != "1" ]; then
    if ${WANS_STATE_CHANGE[$wanId]}; then
      setIptablesFilters --delete $wanId
    fi
  fi

  _error "$message"

  scriptHelper down $wanId
}

# Executa script auxiliares para serem executados apĂ³s UP e DOWN dos links WANS
function scriptHelper(){
  local action=$1
  local wanId=$2

  local iface=$(getConfig "WANS[$wanId].iface")

  mapfile -t scripts < <(find "$SCRIPT_DIR/scripts/$iface/$action/" -maxdepth 1 -type f -executable 2> /dev/null | sort -V)

  for script in "${scripts[@]}"; do
    local result
    if result=$($script 2>&1); then
      _info "Script $(basename "$script") executado com sucesso.\n$result"
    else
      _error "Falha ao executar script $(basename "$script"):\n$result"
    fi
  done
}

# Inicia o daemon
function startDaemon(){
  # Apagar registros de logs
  unset LOG_MESSAGE

  checkRunning
  checkTools
  loadSettings
  validAndSetConfig
  reorderWans

  info "$(header)"

  info "\n$_BOX_TOP"
  info "$_BOX_LINE INICIANDO MULTIWANS"
  info "$_BOX_BOTTOM"

  # Criar lista IPSET com redes locais
  [ ${useListLocalnets:-false} ] && setListIP multiwans-localnets "$LOCALNETS"

  # Desativar RP_FILTER
  setRpFilter off

  local wanId
  for wanId in $(getListIds WANS); do

    local enabled=$(getConfig "WANS[$wanId].enabled")
    local description=$(getConfig "WANS[$wanId].description")
    local orderFailover=$(getConfig "WANS[$wanId].orderFailover")

    info "\n$_BOX_TOP"
    info "$_BOX_LINE CONFIGURANDO LINK $description"
    info "$_BOX_BOTTOM"

    function setConfigWan() {
      if ! $enabled; then
        _warning "O link estĂ¡ DESATIVADO."
        return 0
      fi

      testIfaceAvailable $wanId || return 1
      testIfaceEnabled $wanId || restartIface $wanId || return 1
      testIfaceConnection $wanId || return 1
      testIfaceConfiguration $wanId || return 1

      if [ "$orderFailover" != "" ] && [ "$DEFAULT_GATEWAY" == "" ]; then
        if [ "$(getCurrentDefaultGateway)" == "$wanId" ]; then
          DEFAULT_GATEWAY=$wanId
          _info "O link jĂ¡ estĂ¡ declarado como rota padrĂ£o no sistema."
        elif ! setDefaultGateway $wanId; then
          return 1
        fi
      fi

      if ! setRouteTable --add $wanId; then
        [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0 || return 1
      fi

      if ! setRouteTableGateway --add $wanId; then
        [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0 || return 1
      fi

      if ! setRulesTableRoute --add $wanId; then
        [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0 || return 1
      fi

      if ! setBasicFilters --add $wanId; then
        [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0 || return 1
      fi

      if ! setInputIptablesFilters --add $wanId; then
        [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0 || return 1
      fi

      # Link principal(orderFailover=1) ou link de rota padrĂ£o nĂ£o possuem filtros de marcaĂ§Ă£o de pacotes iptables
      [ "$orderFailover" == "1" ] && return 0
      [ "$DEFAULT_GATEWAY" == "$wanId" ] && return 0

      setIptablesFilters --add $wanId || return 1

      return 0
    }

    if setConfigWan; then
      setOnWan $wanId
    else
      setOffWan $wanId
    fi

  done

  [ "$DEFAULT_GATEWAY" == "" ] && _error "TODOS os links de internet encontram-se OFFLINE.\nContatar equipe de infraestrutura!"

  # Limpa o cache das tabelas de roteamento
  ip route flush cache

  info "$(footer)"
  mail "START"

  # Apagar registros de logs
  unset LOG_MESSAGE
}

# Para o daemon
function stopDaemon(){
  # Definir inĂ­cio de execuĂ§Ă£o de script
  local START_TIME=$(date +%s);

  # VariĂ¡vel utilizada no registro de info do sistema
  local LOG_TIME=$(date +%Y%m%d%H%M%S -d @$START_TIME)

  # VariĂ¡vel utilizada em mensagens para usuĂ¡rio
  local SHOW_TIME=$(date +%d/%m/%Y\ %H:%M:%S -d @$START_TIME)

  # Apagar registros de logs
  unset LOG_MESSAGE

  info "$(header)"

  info "\n$_BOX_TOP"
  info "$_BOX_LINE PARANDO MULTIWANS"
  info "$_BOX_BOTTOM"

  local messageDefaultGateway

  local wanId
  for wanId in $(getListIds WANS); do
    local enabled=$(getConfig "WANS[$wanId].enabled")

    # Se estiver desativado, continuar para o prĂ³ximo link WAN
    $enabled || continue

    local description=$(getConfig "WANS[$wanId].description")
    local orderFailover=$(getConfig "WANS[$wanId].orderFailover")
    local status=$(getConfig "WANS[$wanId].status")
    local gateway=$(getConfig "WANS[$wanId].gateway")

    info "\n$_BOX_TOP"
    info "$_BOX_LINE REMOVENDO CONFIGURAĂ‡ĂƒO DO LINK $description"
    info "$_BOX_BOTTOM"

    # Link principal(orderFailover=1) e link de rota padrĂ£o nĂ£o possuem filtros de marcaĂ§Ă£o de pacotes iptables
    if [ "$orderFailover" != "1" ] || [ "$DEFAULT_GATEWAY" != "$wanId" ]; then
      setIptablesFilters --delete $wanId
    fi

    setInputIptablesFilters --delete $wanId

    setBasicFilters --delete $wanId

    setRulesTableRoute --delete $wanId

    setRouteTableGateway --delete $wanId

    setRouteTable --delete $wanId

    [ "$status" == "OFF" ] && continue

    if [ "$DEFAULT_GATEWAY" == "$wanId" ]; then
      messageDefaultGateway="${description}[$gateway]"
      continue
    fi

    [ "$orderFailover" == "disabled" ] && continue

    testIfaceAvailable $wanId || continue
    testIfaceEnabled $wanId || restartIface $wanId || continue
    testIfaceConnection $wanId || continue
    testIfaceConfiguration $wanId || continue

    setDefaultGateway $wanId
  done

  if [ "$messageDefaultGateway" ]; then
    _info "Rota padrĂ£o atual: $messageDefaultGateway."
  else
    _error "Nenhuma rota padrĂ£o definida no sistema."
  fi

  # Habilitar RP_FILTER
  setRpFilter on

  # Limpa o cache das tabelas de roteamento
  ip route flush cache

  # Remover arquivo de status de links
  rm -f $DAEMON_STATUS_FILE 2> /dev/null

  info "$(footer)"
  mail "STOP"

  # Apagar registros de logs
  unset LOG_MESSAGE
}

# Testa as configuraĂ§Ăµes e conectividade dos links WANS
function testWans(){
  # Definir inĂ­cio de execuĂ§Ă£o de script
  local START_TIME=$(date +%s);

  # VariĂ¡vel utilizada no registro de info do sistema
  local LOG_TIME=$(date +%Y%m%d%H%M%S -d @$START_TIME)

  # VariĂ¡vel utilizada em mensagens para usuĂ¡rio
  local SHOW_TIME=$(date +%d/%m/%Y\ %H:%M:%S -d @$START_TIME)

  # Apagar registros de logs
  unset LOG_MESSAGE

  # VariĂ¡vel responsĂ¡vel por identificar se gateway padrĂ£o foi definido
  local isSetDefaultGateway=false

  # Validar RP_FILTER
  testRpFilter || setRpFilter off

  local wanId
  for wanId in $(getListIds WANS); do

    local enabled=$(getConfig "WANS[$wanId].enabled")

    # Se estiver desativado, continuar para o prĂ³ximo link WAN
    $enabled || continue

    WANS_STATE_CHANGE[wanId]=false

    local description=$(getConfig "WANS[$wanId].description")
    local orderFailover=$(getConfig "WANS[$wanId].orderFailover")

    info "\n$_BOX_TOP"
    info "$_BOX_LINE MONITORANDO LINK $description"
    info "$_BOX_BOTTOM"

    function testWan() {
      testIfaceAvailable $wanId || return 1
      testIfaceEnabled $wanId || { setStatusWan $wanId OFF; restartIface $wanId; } || return 1
      testIfaceConnection $wanId || return 1
      testIfaceConfiguration $wanId || return 1

      testRouteTable $wanId || { setStatusWan $wanId OFF; setRouteTable --add $wanId; } || return 1

      testRouteTableGateway $wanId || { setStatusWan $wanId OFF; setRouteTableGateway --add $wanId; } || return 1

      testRulesTableRoute $wanId || { setStatusWan $wanId OFF; setRulesTableRoute --add $wanId; } || return 1

      testBasicFilters $wanId || { setStatusWan $wanId OFF; setBasicFilters --add $wanId; } || return 1

      testInputIptablesFilters $wanId || { setStatusWan $wanId OFF; setInputIptablesFilters --add $wanId; } || return 1

      testPing $wanId || return 1
    }

    if testWan; then
      setStatusWan "$wanId" ON
    else
      setOffWan "$wanId"
      continue
    fi

    ########################################################################
    # O link estĂ¡ ONLINE.
    # Deve-se realizar teste de definiĂ§Ă£o de rota padrĂ£o e regras iptables.
    ########################################################################

    # Link sem order de failover nĂ£o pode ser definido como rota padrĂ£o
    if [ "$orderFailover" != "disabled" ] && ! $isSetDefaultGateway; then

      if [ "$DEFAULT_GATEWAY" == "$wanId" ]; then
        if [ "$(getCurrentDefaultGateway)" == "$wanId" ]; then
          isSetDefaultGateway=true
          continue
        else
          # A rota padrĂ£o atual estĂ¡ diferente da definiĂ§Ă£o do sistema, portanto o link atualmente estĂ¡ OFFLINE
          setStatusWan $wanId OFF
        fi
      fi

      if setDefaultGateway $wanId; then
        isSetDefaultGateway=true

        if [ "$orderFailover" != "1" ]; then
          # Remove regras de marcaĂ§Ă£o de pacotes do iptables
          if ! setIptablesFilters --delete $wanId; then
            # NĂ£o Ă© necessĂ¡rio registrar o erro em setOffWan(), pois este erro nĂ£o deixa o link OFFLINE,
            # pois o mesmo jĂ¡ foi definido como rota padrĂ£o.
            _error "Verifique os logs acima e contatar equipe de infraestrutura!"
          fi
        fi

        # Limpa o cache das tabelas de roteamento
        ip route flush cache

        setOnWan $wanId

        continue
      else
        if [ "$orderFailover" == "1" ]; then
          setOffWan $wanId "O link \"$description\" estĂ¡ ONLINE mas nĂ£o foi possĂ­vel ativar o serviĂ§o.\nVerifique os logs acima e contatar equipe de infraestrutura!"
          continue
        else
          _error "Verifique os logs acima e Contatar equipe de infraestrutura!"
        fi
      fi
    fi

    ####################################################################################
    # Caso o link nĂ£o seja definido como rota padrĂ£o, executa-se as anĂ¡lises abaixo:
    ####################################################################################

    local useListLocalnets=$(getConfig "WANS[$wanId].useListLocalnets")

    if ${useListLocalnets:-false}; then
      if ! testListIP multiwans-localnets "$LOCALNETS"; then
        # A lista nĂ£o existe ou falta endereĂ§os IP's
        setStatusWan $wanId OFF

        if setListIP multiwans-localnets "$LOCALNETS"; then
          setStatusWan "$wanId" ON
        else
          setOffWan $wanId "O link \"$description\" estĂ¡ ONLINE mas nĂ£o foi possĂ­vel ativar o serviĂ§o.\nVerifique os logs acima e contatar equipe de infraestrutura!"
          continue
        fi
      fi
    fi

    if ! testIptablesFilters $wanId; then
      # Falta regras de redirecionamento, portanto o link atualmente estĂ¡ OFFLINE
      setStatusWan $wanId OFF

      # Aplica regras de marcaĂ§Ă£o de pacotes do iptables
      if setIptablesFilters --add $wanId; then
        # Limpa o cache das tabelas de roteamento
        ip route flush cache

        setOnWan $wanId
      else
        setOffWan $wanId "O link \"$description\" estĂ¡ ONLINE mas nĂ£o foi possĂ­vel ativar o serviĂ§o.\nVerifique os logs acima e contatar equipe de infraestrutura!"
      fi
    fi

  done

  # Define o assunto do alerta
  local subject=""

  # Verifica se hĂ¡ erros na mensagem de log
  # OBS: Utilizado regex para que possĂ­veis logs de auditoria nĂ£o capturem a palavra ERROR
  #      e acabem gerando falso positivo em alertas.
  if grep -q '[E][R][R][O][R]:' <<< "$LOG_MESSAGE"; then
    if grep -q "true" <<< "${WANS_STATE_CHANGE[@]}" || (( ALERT_COUNT < ALERTS_MAX )) || (( START_TIME - LAST_ALERT_TIME >= ALERTS_INTERVAL * 60 )); then
      subject="ERROR"
    fi
  elif grep -q "true" <<< "${WANS_STATE_CHANGE[@]}"; then
    subject="WARNING"
  else
    ALERT_COUNT=0
    LAST_ALERT_TIME=0
  fi

  # Envia e-mail se necessĂ¡rio
  if [ "$subject" ]; then
    LOG_MESSAGE="$(header)${LOG_MESSAGE}$(footer)"
    mail "$subject"

    ((ALERT_COUNT++))
    LAST_ALERT_TIME=$(date +%s)
  fi

  # Apagar registros de logs
  unset LOG_MESSAGE
}

###############################################################################################################
# Main Script
###############################################################################################################

# Tratamento de sinais enviados ao processo do script
# SIGINT: Interromper processo ao pressionar Ctrl-C no teclado.
trap '_exit SIGINT' SIGINT
# SIGQUIT: Finalizar processo ao pressionar Ctrl-\ no teclado.
trap '_exit SIGQUIT' SIGQUIT
# SIGTERM: Finalizar processo atravĂ©s dos comandos "kill" ou "killall".
trap '_exit SIGTERM' SIGTERM
# SIGHUP: Desligar ou sair de um processo em execuĂ§Ă£o em primeiro plano de um terminal
trap '_exit SIGHUP' SIGHUP
# EXIT: Ă© um pseudo-sinal lanĂ§ado pelo bash quando o script Ă© finalizado com uma chamada direta a exit
#       ou o fim do script Ă© alcanĂ§ado. Outra situaĂ§Ă£o em que esse sinal Ă© gerado, acontece quando um
#       programa Ă© executado incorretamente caso a opĂ§Ă£o errexit (set -e) esteja ativada.
trap '_exit EXIT $?' EXIT

# Iniciando sistema
startDaemon

while true; do

  startTime=$(date +%s)

  # Testa links
  testWans

  endTime=$(date +%s)

  sleepTime=0
  # Verifique o tempo necessĂ¡rio de espera antes da prĂ³xima execuĂ§Ă£o.
  # Ex: Se a execuĂ§Ă£o levar mais tempo do que o intervalo desejado (por exemplo, 1 minuto),
  #     entĂ£o a prĂ³xima execuĂ§Ă£o deve iniciar imediatamente, sem aguardar.
  if ((endTime - startTime < DAEMON_RUN_INTERVAL)) then
    sleepTime=$((DAEMON_RUN_INTERVAL - (endTime - startTime) ))
  fi

  # Aguarda o tempo necessĂ¡rio antes do prĂ³ximo teste.
  # O uso de um loop `for` para aguardar foi necessĂ¡rio para garantir que o comando `trap`,
  # responsĂ¡vel por manipular sinais de interrupĂ§Ă£o do processo, funcione corretamente.
  # Se apenas o `sleep` fosse utilizado, o processo sĂ³ seria finalizado apĂ³s a conclusĂ£o
  # do tempo de espera, impedindo a interrupĂ§Ă£o imediata em caso de sinal de tĂ©rmino.
  for ((i=0;i<sleepTime;i++)); do
    sleep 1
  done

done
