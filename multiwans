# Define/Remove regras de roteamento da tabela de roteamento dos links WAN
function setRulesTableRoute(){
  local opt=$1
  local wanId=$2

  local iface=$(getConfig "WANS[$wanId].iface")
  local ip=$(getConfig "WANS[$wanId].ip")
  local mark=$(getConfig "WANS[$wanId].mark")
  local table="WAN${mark}"

  # Remove todas as regras definidas para a tabela
  while [ "$(ip rule show table ${table} 2>/dev/null)" ]; do
    ip rule delete table $table 2>/dev/null
  done

  # Remove todas as regras definidas para interface de entrada
  while [ "$(ip rule show iif $iface 2>/dev/null)" ]; do
    ip rule delete iif $iface 2>/dev/null
  done

  if [ "$opt" == "--add" ]; then
    local result
    # IMPORTANTE: - Aplique as regras nesta ordem:
    #                 1. Origem do pacote
    #                 2. MarcaĂ§Ă£o de pacotes
    #                 3. Interface de entrada
    #
    #             - A regra da interface de entrada Ă© essencial, pois pacotes vindos da internet tambĂ©m sĂ£o marcados.
    #               Sem essa regra, o roteamento pode falhar, fazendo com que os pacotes saiam pela mesma interface em que chegaram.
    if result=$(ip rule add from $ip table $table 2>&1 && ip rule add fwmark $mark table $table 2>&1 && ip rule add iif $iface from all lookup main 2>&1); then
      _success "Definido regras de roteamento[Origem: \"$ip\" e MarcaĂ§Ă£o: \"$mark\"] da tabela de roteamento \"$table\"."
      return 0
    else
      _error "Falha ao definir regras de roteamento[Origem: \"$ip\" e MarcaĂ§Ă£o: \"$mark\"] da tabela de roteamento \"$table\":\n$result"
      return 1
    fi
  else
    _success "Removido regras de roteamento[Origem: \"$ip\" e MarcaĂ§Ă£o: \"$mark\"] da tabela de roteamento \"$table\"."
    return 0
  fi
}

# Testa se as regras de roteamento da tabela de roteamento dos links WAN estĂ£o definidas
function testRulesTableRoute(){
  local wanId=$1

  local iface=$(getConfig "WANS[$wanId].iface")
  local ip=$(getConfig "WANS[$wanId].ip")
  local mark=$(getConfig "WANS[$wanId].mark")
  local mark_hex=$(printf "0x%x" $mark)
  local table="WAN${mark}"

  local rules=$(ip rule show table $table 2>/dev/null; ip rule show iif $iface 2>/dev/null)
  local from_ip_count=$(grep -cE "from $ip lookup $table$" <<< "$rules")
  local from_any_count=$(grep -cE "from [0-9\.\/]+ lookup $table$" <<< "$rules")
  local fwmark_count=$(grep -cE "from all fwmark $mark_hex lookup $table$" <<< "$rules")
  local fwmark_any_count=$(grep -cE "from all fwmark .* lookup $table$" <<< "$rules")
  local iif_count=$(grep -cE "from all iif $iface lookup main$" <<< "$rules")

  if (( from_ip_count == 0 )); then
    _error "A regra de roteamento por origem da tabela \"$table\" nĂ£o estĂ¡ definida."
    return 1
  elif (( from_any_count > 1 )); then
    _error "Existe mais de uma regra de roteamento por origem na tabela \"$table\"."
    return 1
  elif (( fwmark_count == 0 )); then
    _error "A regra de roteamento por marcaĂ§Ă£o de pacotes na tabela \"$table\" nĂ£o estĂ¡ definida."
    return 1
  elif (( fwmark_any_count > 1 )); then
    _error "Existe mais de uma regra de roteamento por marcaĂ§Ă£o de pacotes na tabela \"$table\"."
    return 1
  elif (( iif_count == 0 )); then
    _error "A regra de roteamento para interface de entrada \"$iface\" nĂ£o estĂ¡ definida."
    return 1
  fi

  return 0
}

# Define/Remove filtros bĂ¡sicos de marcaĂ§Ă£o de pacotes iptables
function setBasicFilters(){
  local opt=$1

  # ComentĂ¡rio das regras iptables
  local comment="MULTIWANS_BASIC_MARK"

  # Remove todos os filtros definidos
  while iptables -t mangle -C PREROUTING -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2> /dev/null; do
    iptables -t mangle -D PREROUTING -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2> /dev/null
  done

  while iptables -t mangle -C OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2> /dev/null; do
    iptables -t mangle -D OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2> /dev/null
  done

  while iptables -t mangle -C POSTROUTING -m conntrack --ctstate NEW -m mark ! --mark 0 -m comment --comment "$comment" -j CONNMARK --save-mark 2> /dev/null; do
    iptables -t mangle -D POSTROUTING -m conntrack --ctstate NEW -m mark ! --mark 0 -m comment --comment "$comment" -j CONNMARK --save-mark 2> /dev/null
  done

  if [ "$opt" == "--add" ]; then
    local result

    # Pacotes em PREROUTING com estados ESTABLISHED ou RELATED com marcaĂ§Ă£o de pacotes CONNMARK definida, devem ter a marcaĂ§Ă£o netfilter aplicada/restaurada
    if result=$(iptables -t mangle -I PREROUTING -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2>&1); then
      # Pacotes em OUTPUT com estados ESTABLISHED ou RELATED com marcaĂ§Ă£o de pacotes CONNMARK definida, devem ter a marcaĂ§Ă£o netfilter aplicada/restaurada
      if result=$(iptables -t mangle -I OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -m comment --comment "$comment" -j CONNMARK --restore-mark 2>&1); then
        # Pacotes em POSTROUTING com estado NEW com marcaĂ§Ă£o de pacotes netfilter definida, devem ter a marcaĂ§Ă£o CONNMARK aplicada
        if result=$(iptables -t mangle -I POSTROUTING -m conntrack --ctstate NEW -m mark ! --mark 0 -m comment --comment "$comment" -j CONNMARK --save-mark 2>&1); then
          _success "Definido filtros bĂ¡sicos de marcaĂ§Ă£o de pacotes iptables."
          return 0
        fi
      fi
    fi

    _error "Falha ao definir filtros bĂ¡sicos de marcaĂ§Ă£o de pacotes iptables:\n$result"
    return 1
  else
    _success "Removido filtros bĂ¡sicos de marcaĂ§Ă£o de pacotes iptables."
    return 0
  fi
}

# Testa se os filtros bĂ¡sicos de marcaĂ§Ă£o de pacotes iptables estĂ£o definidos
