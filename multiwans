# Cria lista IPset de IP's
function setListIP(){
  local list=$1
  local ips=$2

  local result

  if $IPSET list -name $list &>/dev/null; then
    if ! result=$($IPSET flush ${list} 2>&1 >/dev/null); then
      # shellcheck disable=SC2001
      _error "Falha na limpeza da lista de IP's \"${list}\":\n$(sed -e 's/ipset v[0-9\.]\+: //g' <<< "$result")"
      die 1
    fi
  elif result=$($IPSET create $list -exist hash:net family inet maxelem 1024 2>&1 >/dev/null); then
    _success "Criado lista de IP's $list."
  else
    # shellcheck disable=SC2001
    _error "Falha ao criar lista de IP's \"$list\":\n$(sed -e 's/ipset v[0-9\.]\+: //g' <<< "$result")"
    die 1
  fi

  local ip=""
  for ip in $ips; do
    if ! result=$($IPSET add -exist $list $ip 2>&1 >/dev/null); then
      # shellcheck disable=SC2001
      _error "NĂ£o foi possĂ­vel adicionar o endereĂ§o IP \"$ip\" na lista \"$list\":\n$(sed -e 's/ipset v[0-9\.]\+: //g' <<< "$result")"
      die 1
    fi
  done
}

# Testa lista IPset de IP's
function testListIP(){
  local list=$1
  local ips=$2

  if ! $IPSET list -name $list &>/dev/null; then
    _error "NĂ£o existe lista de IP's \"$list\"."
    return 1
  fi

  local ip=""
  for ip in $ips; do
    if ! $IPSET test -name $list $ip &>/dev/null; then
      _error "O IP \"$ip\" nĂ£o estĂ¡ declarado na lista de IP's \"$list\"."
      return 1
    fi
  done
}

# Ativa/Desativa RP Filter
function setRpFilter() {
  local action=$1

  [ "$action" == "on" ] && value=1 || value=0

  echo 0 | tee /proc/sys/net/ipv4/conf/*/rp_filter > /dev/null

  _success "$([ "$action" == "on" ] && echo "Ativado" || echo "Desativado") RP Filter em todas as interface do sistema."
}

