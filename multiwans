# Emite duraĂ§Ă£o do processamento do script
function runtime(){
  local endTime=$(date +%s)

  local totalTime=$((endTime - START_TIME))

  local duration=""
  if [ "$totalTime" != "0" ]; then
    local d h m s parts=()
    (( d = totalTime / 60 / 60 / 24 )) && parts+=("$d dia(s)")
    (( h = totalTime / 60 / 60 % 24 )) && parts+=("$h hora(s)")
    (( m = totalTime / 60 % 60 )) && parts+=("$m min.")
    (( s = totalTime % 60 )) && parts+=("$s seg.")

    duration="$(sed -e 's/,$//' -e 's/\(.*\), /\1 e /' <<< "${parts[@]/%/,}")"
  else
    duration="0 seg."
  fi

  echo -e "\n$_BOX_TOP"
  echo "$_BOX_LINE PROCESSAMENTO FINALIZADO"
  echo "$_BOX_INNER"

  column -s'Â£' -t < <(
    echo "$_BOX_LINE Fim do processo:Â£$(date +%Y-%m-%d\ %H:%M:%S -d @${endTime})"
    echo "$_BOX_LINE DuraĂ§Ă£o do processo:Â£$duration"
  )

  echo "$_BOX_BOTTOM"
}

# Verifica se o daemon jĂ¡ estĂ¡ em execuĂ§Ă£o
function checkRunning() {
  # Captura os PIDs dos processos que correspondem ao nome do script
  # O padrĂ£o `.[ /]${SCRIPT_NAME}( |\$)` garante que:
  # - O nome do script aparece como um comando isolado (evita correspondĂªncia parcial).
  # - Ele pode estar precedido por espaĂ§o ou `/` (indicando caminho absoluto).
  # - Ă‰ seguido por um espaĂ§o ou o final da linha (`$`), evitando partes de outros comandos.
  local pid=$(pgrep -f ".[ /]${SCRIPT_NAME}( |\$)")

  # Remove o prĂ³prio PID do script para evitar auto correspondĂªncia
  pid=$(awk -v pid=$SCRIPT_PID '$1 != pid {print $1}' <<< "$pid")

  if [ -n "$pid" ]; then
    local p
    for p in $pid; do
      # ObtĂ©m o comando completo usado para iniciar o processo
      local cmd=$(ps -o cmd= -p "$p")

      # Verifica se o processo em questĂ£o Ă© um script bash
      if [[ "$cmd" =~ bash ]]; then
        _error "Script jĂ¡ estĂ¡ em execuĂ§Ă£o.\nPID do processo em execuĂ§Ă£o: $p."
        die 1
      fi
    done
  fi
}

# Instala ou atualiza a ferramenta yq
function installYq(){
  # Verificar a Ăºltima versĂ£o do `yq`
  local latest_version
  if ! latest_version=$($CURL -s https://api.github.com/repos/mikefarah/yq/releases/latest 2>&1 | grep '"tag_name":' | cut -d '"' -f 4) || [ "$latest_version" == "" ]; then
    _warning "NĂ£o foi possĂ­vel descobrir Ăºltima versĂ£o da ferramenta \"yq\":\n$latest_version"
    return 1
  fi

  local installed_version="none"
  if [ -f "$YQ" ] && [ -x "$YQ" ]; then
    installed_version=$($YQ --version | awk '{print $NF}')
  fi

  [ "$installed_version" == "$latest_version" ] && return 0

  # Baixar o arquivo e capturar erros
  log_curl_err=$(mktemp)
  rm -f /tmp/yq_linux_amd64* 2> /dev/null
  if ! $CURL -L https://github.com/mikefarah/yq/releases/download/${latest_version}/yq_linux_amd64.tar.gz -o /tmp/yq_linux_amd64.tar.gz 2> $log_curl_err; then
    _warning "Falha ao realizar download da ferramenta \"yq\" versĂ£o ${latest_version}:\n$(cat $log_curl_err)"
    return 1
  fi

  # Extrair e mover para /usr/local/bin
  log_tar_err=$(mktemp)
  if ! tar xzf "/tmp/yq_linux_amd64.tar.gz" -C /tmp/ 2> $log_tar_err; then
    _warning "Falha ao extrair a ferramenta \"yq\" versĂ£o ${latest_version}:\n$(cat $log_tar_err)"
    return 1
  fi

  install -m 755 /tmp/yq_linux_amd64 $YQ
  rm -f /tmp/yq_linux_amd64* $log_curl_err $log_tar_err

  _success "\"yq\" instalado/atualizado com versĂ£o ${latest_version}."
}

