  if [ "$opt" == "--add" ]; then
    local result
    if result=$( (echo "$mark $table" >> /etc/iproute2/rt_tables) 2>&1); then
      _success "Criado tabela de roteamento \"$table\"."
      return 0
    else
      _error "Falha ao criar tabela de roteamento \"$table\":\n$result"
