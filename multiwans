# Enviar email de alerta
function mail(){
  local status=$1

  [ "$EMAIL_USERNAME" ] && local _login="-xu $EMAIL_USERNAME -xp $EMAIL_PASSWORD"

  local result
  result=$($SENDEMAIL -f $EMAIL_FROM \
                      -t $EMAIL_TO \
                      -u "${status}: $DESCRIPTION: $HOSTNAME ($SHOW_TIME)" \
                      -o reply-to=$EMAIL_FROM \
                      -o message-charset=utf-8 \
                      -s $EMAIL_HOST:$EMAIL_PORT \
                      $_login \
                      -m "$(echo -e "$LOG_MESSAGE" | sed '1s/^-/\n-/g')" \
                      2>&1
  )

  # shellcheck disable=SC2181
  if [ "$?" == "0" ]; then
    _info "$result"
  else
    _error "$result"
  fi
}

# Obter uptime do sistema
function uptime(){
  local uptime=$(cut -d. -f1 /proc/uptime)

  local d h m s parts=()
  (( d = uptime / 60 / 60 / 24 )) && parts+=("$d dia(s)")
  (( h = uptime / 60 / 60 % 24 )) && parts+=("$h hora(s)")
  (( m = uptime / 60 % 60 )) && parts+=("$m min.")
  (( s = uptime % 60 )) && parts+=("$s seg.")

  sed -e 's/,$//' -e 's/\(.*\), /\1 e /' <<< "${parts[@]/%/,}"

}

