# Define/Remove filtro INPUT de marcaĂ§Ă£o de pacotes iptables
function setInputIptablesFilters(){
  local opt=$1
  local wanId=$2

  local description=$(getConfig "WANS[$wanId].description")
  local iface=$(getConfig "WANS[$wanId].iface")
  local mark=$(getConfig "WANS[$wanId].mark")

  # Formatar comentĂ¡rio
  local comment="MULTIWANS_INPUT_$(sed -e 's/[[:space:]]/_/g' -e 's/.*/\U&/' <<< "$description")"

  # Remove todos os filtros definidos
	#   IMPORTANTE:
	#     A condiĂ§Ă£o "-m policy --pol none --dir in" garante que apenas pacotes que NĂƒO
	#     fazem parte de uma polĂ­tica IPsec sejam marcados.
	#
	#     Sem esse filtro, pacotes IPsec (ESP/UDP 500/4500) que chegam pela interface
	#     WAN seriam marcados ainda no PREROUTING, antes da decapsulaĂ§Ă£o (XFRM). Isso faz
	#     com que a marca (fwmark) seja associada ao fluxo (conntrack) e acabe afetando
	#     tambĂ©m o trĂ¡fego jĂ¡ descriptografado (ex: via VTI).
	#
	#     O efeito colateral Ă© que o trĂ¡fego interno do tĂºnel pode herdar a marca e ser
	#     roteado incorretamente (ex: sair pela WAN ao invĂ©s da interface do tĂºnel),
	#     quebrando o fluxo IPsec.
	#
	#     Portanto, filtramos apenas "--pol none" para garantir que:
	#       - TrĂ¡fego IPsec nĂ£o seja marcado
	#       - Apenas trĂ¡fego "clear-text" (internet normal) participe do balanceamento multiwan
	local rule=(
		-i "$iface"
		-m policy --pol none --dir in
		-m conntrack --ctstate NEW
		-m comment --comment "$comment"
		-j MARK --set-mark $mark
	)

	while iptables -t mangle -C PREROUTING "${rule[@]}" 2>/dev/null; do
		iptables -t mangle -D PREROUTING "${rule[@]}" 2>/dev/null
	done

  if [ "$opt" == "--add" ]; then
    local result=""

    # Pacotes em PREROUTING entrando pela interface WAN com estado NEW, devem ter a marcaĂ§Ă£o netfilter aplicada
    if result=$(iptables -t mangle -I PREROUTING "${rule[@]}" 2>&1); then
      _success "Definido filtro INPUT \"$iface\" de marcaĂ§Ă£o de pacotes iptables."
      return 0
    else
      _error "Falha ao definir filtro INPUT \"$iface\" de marcaĂ§Ă£o de pacotes iptables:\n$result"
      return 1
    fi
  else
    _success "Removido filtro INPUT \"$iface\" de marcaĂ§Ă£o de pacotes iptables"
    return 0
  fi
}

# Testa se o filtro INPUT de marcaĂ§Ă£o de pacotes iptables estĂ¡ definido
